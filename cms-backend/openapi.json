{
  "openapi": "3.0.0",
  "info": {
    "title": "Full-Stack CMS API",
    "description": "Enterprise-grade REST API for a full-stack CMS with JWT auth and RBAC",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "http://localhost:3000",
      "description": "Local Development"
    }
  ],
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    }
  },
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "paths": {
    "/": {
      "get": {
        "tags": ["health"],
        "summary": "API Status",
        "description": "Check if API is running",
        "responses": {
          "200": {
            "description": "API is running"
          }
        }
      }
    },
    "/health": {
      "get": {
        "tags": ["health"],
        "summary": "Health Check",
        "description": "Health check for load balancers and K8s probes",
        "responses": {
          "200": {
            "description": "Service is healthy"
          }
        }
      }
    },
    "/auth/login": {
      "post": {
        "tags": ["auth"],
        "summary": "Login",
        "description": "Authenticate user and get JWT token",
        "security": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "email": {
                    "type": "string",
                    "example": "admin@example.com"
                  },
                  "password": {
                    "type": "string",
                    "example": "changeme123"
                  }
                },
                "required": ["email", "password"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Login successful"
          },
          "400": {
            "description": "Invalid credentials"
          }
        }
      }
    },
    "/users": {
      "get": {
        "tags": ["users"],
        "summary": "List Users",
        "description": "Get paginated list of users (Admin only)",
        "parameters": [
          {
            "name": "page",
            "in": "query",
            "schema": { "type": "integer", "default": 1 }
          },
          {
            "name": "limit",
            "in": "query",
            "schema": { "type": "integer", "default": 10, "maximum": 50 }
          }
        ],
        "responses": {
          "200": {
            "description": "Users retrieved"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/users/{id}": {
      "get": {
        "tags": ["users"],
        "summary": "Get User by ID",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string", "format": "uuid" }
          }
        ],
        "responses": {
          "200": {
            "description": "User retrieved"
          },
          "404": {
            "description": "User not found"
          }
        }
      },
      "patch": {
        "tags": ["users"],
        "summary": "Update User",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string", "format": "uuid" }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "email": { "type": "string" },
                  "firstName": { "type": "string" },
                  "lastName": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "User updated"
          }
        }
      },
      "delete": {
        "tags": ["users"],
        "summary": "Delete User",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string", "format": "uuid" }
          }
        ],
        "responses": {
          "200": {
            "description": "User deleted"
          }
        }
      }
    },
    "/users/{id}/status": {
      "patch": {
        "tags": ["users"],
        "summary": "Update User Status",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string", "format": "uuid" }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "isActive": { "type": "boolean" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "User status updated"
          }
        }
      }
    },
    "/roles": {
      "post": {
        "tags": ["roles"],
        "summary": "Create Role",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "name": { "type": "string", "example": "editor" },
                  "description": { "type": "string" }
                },
                "required": ["name"]
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Role created"
          }
        }
      },
      "get": {
        "tags": ["roles"],
        "summary": "List Roles",
        "parameters": [
          {
            "name": "page",
            "in": "query",
            "schema": { "type": "integer", "default": 1 }
          },
          {
            "name": "limit",
            "in": "query",
            "schema": { "type": "integer", "default": 10, "maximum": 50 }
          }
        ],
        "responses": {
          "200": {
            "description": "Roles retrieved"
          }
        }
      }
    },
    "/roles/{id}": {
      "get": {
        "tags": ["roles"],
        "summary": "Get Role by ID",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string", "format": "uuid" }
          }
        ],
        "responses": {
          "200": {
            "description": "Role retrieved"
          }
        }
      },
      "patch": {
        "tags": ["roles"],
        "summary": "Update Role",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string", "format": "uuid" }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "name": { "type": "string" },
                  "description": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Role updated"
          }
        }
      },
      "delete": {
        "tags": ["roles"],
        "summary": "Delete Role",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string", "format": "uuid" }
          }
        ],
        "responses": {
          "200": {
            "description": "Role deleted"
          }
        }
      }
    },
    "/roles/{id}/permissions": {
      "patch": {
        "tags": ["roles"],
        "summary": "Assign Permissions to Role",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string", "format": "uuid" }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "permissionIds": {
                    "type": "array",
                    "items": { "type": "string", "format": "uuid" }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Permissions assigned"
          }
        }
      }
    },
    "/permissions": {
      "post": {
        "tags": ["permissions"],
        "summary": "Create Permission",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "key": { "type": "string", "example": "blog.create" },
                  "description": { "type": "string" }
                },
                "required": ["key"]
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Permission created"
          }
        }
      },
      "get": {
        "tags": ["permissions"],
        "summary": "List Permissions",
        "parameters": [
          {
            "name": "page",
            "in": "query",
            "schema": { "type": "integer", "default": 1 }
          },
          {
            "name": "limit",
            "in": "query",
            "schema": { "type": "integer", "default": 10, "maximum": 50 }
          }
        ],
        "responses": {
          "200": {
            "description": "Permissions retrieved"
          }
        }
      }
    },
    "/blogs": {
      "post": {
        "tags": ["blogs"],
        "summary": "Create Blog Post",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "slug": { "type": "string" },
                  "status": {
                    "type": "string",
                    "enum": ["draft", "published"]
                  },
                  "translations": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "properties": {
                        "languageCode": { "type": "string" },
                        "title": { "type": "string" },
                        "content": { "type": "string" }
                      }
                    }
                  }
                }
              },
              "examples": {
                "EnglishAndArabic": {
                  "value": {
                    "slug": "getting-started-with-nextjs",
                    "status": "published",
                    "translations": [
                      {
                        "languageCode": "en",
                        "title": "Getting Started with Next.js",
                        "content": "Next.js is a React framework for building fast, modern web applications. In this comprehensive guide, we'll explore the foundational concepts, best practices, and advanced techniques to help you build scalable applications. Learn about server-side rendering, static generation, API routes, and more."
                      },
                      {
                        "languageCode": "ar",
                        "title": "البدء مع Next.js",
                        "content": "Next.js هو إطار عمل React لبناء تطبيقات ويب سريعة وحديثة. في هذا الدليل الشامل، سوف نستكشف المفاهيم الأساسية وأفضل الممارسات والتقنيات المتقدمة لمساعدتك في بناء تطبيقات قابلة للتوسع. تعرف على العرض من جانب الخادم والتوليد الثابت ومسارات واجهة برمجة التطبيقات والمزيد."
                      }
                    ]
                  }
                },
                "TechTutorial": {
                  "value": {
                    "slug": "mastering-typescript-generics",
                    "status": "draft",
                    "translations": [
                      {
                        "languageCode": "en",
                        "title": "Mastering TypeScript Generics",
                        "content": "TypeScript generics allow you to create flexible and reusable code components. This tutorial covers generic functions, interfaces, classes, and constraints. Understand how to write type-safe code that works with multiple data types while maintaining full type checking."
                      },
                      {
                        "languageCode": "ar",
                        "title": "إتقان النوع العام في TypeScript",
                        "content": "تسمح النماذج العامة في TypeScript بإنشاء مكونات كود مرنة وقابلة لإعادة الاستخدام. يغطي هذا البرنامج التعليمي الوظائف والواجهات والفئات العامة والقيود. افهم كيفية كتابة كود آمن من النوع يعمل مع أنواع بيانات متعددة مع الحفاظ على التحقق الكامل من النوع."
                      }
                    ]
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Blog created"
          }
        }
      },
      "get": {
        "tags": ["blogs"],
        "summary": "List Blog Posts (Admin)",
        "parameters": [
          {
            "name": "page",
            "in": "query",
            "schema": { "type": "integer", "default": 1 }
          },
          {
            "name": "limit",
            "in": "query",
            "schema": { "type": "integer", "default": 10, "maximum": 50 }
          }
        ],
        "responses": {
          "200": {
            "description": "Blogs retrieved"
          }
        }
      }
    },
    "/blogs/public": {
